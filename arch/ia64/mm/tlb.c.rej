--- arch/ia64/mm/tlb.c	2003-11-28 18:26:19.000000000 +0000
+++ arch/ia64/mm/tlb.c	2004-01-06 12:45:27.000000000 +0000
@@ -75,7 +75,7 @@
 	 * and because interrupts are disabled during context switch.
 	 */
 	for (i = 0; i < NR_CPUS; ++i)
-		if (i != smp_processor_id())
+		if (cpu_online(i) && (i != smp_processor_id()))
 			cpu_data(i)->need_tlb_flush = 1;
 	local_flush_tlb_all();
 }
