--- arch/mips64/mm/pg-sb1.c	2003-08-25 11:44:40.000000000 +0000
+++ arch/mips64/mm/pg-sb1.c	2004-01-06 12:42:27.000000000 +0000
@@ -2,6 +2,7 @@
