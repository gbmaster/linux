--- arch/sparc/kernel/devices.c	2003-11-28 18:26:19.000000000 +0000
+++ arch/sparc/kernel/devices.c	2004-01-06 12:46:07.000000000 +0000
@@ -72,7 +72,7 @@
 		if (linux_num_cpus == 0) {
 			printk("No CPU nodes found, cannot continue.\n");
 			/* Probably a sun4e, Sun is trying to trick us ;-) */
-			halt();
+			prom_halt();
 		}
 		printk("Found %d CPU prom device tree node(s).\n", linux_num_cpus);
 	}
