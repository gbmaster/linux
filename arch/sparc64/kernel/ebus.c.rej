--- arch/sparc64/kernel/ebus.c	2002-08-03 00:39:43.000000000 +0000
+++ arch/sparc64/kernel/ebus.c	2004-01-06 12:43:34.000000000 +0000
@@ -177,7 +177,8 @@
 
 static int __init child_regs_nonstandard(struct linux_ebus_device *dev)
 {
-	if (!strcmp(dev->prom_name, "i2c"))
+	if (!strcmp(dev->prom_name, "i2c") ||
+	    !strcmp(dev->prom_name, "SUNW,lombus"))
 		return 1;
 	return 0;
 }
