--- arch/mips/sibyte/cfe/smp.c	2003-08-25 11:44:40.000000000 +0000
+++ arch/mips/sibyte/cfe/smp.c	2004-01-06 12:46:34.000000000 +0000
@@ -47,12 +47,12 @@
 	unsigned int imask = STATUSF_IP4 | STATUSF_IP3 | STATUSF_IP2 |
 		STATUSF_IP1 | STATUSF_IP0;
 
+	/* cache and TLB setup */
+	load_mmu();
+
 	/* Enable basic interrupts */
 	change_c0_status(ST0_IM, imask);
 	set_c0_status(ST0_IE);
-
-	/* cache and TLB setup */
-	load_mmu();
