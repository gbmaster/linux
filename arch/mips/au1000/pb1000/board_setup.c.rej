--- arch/mips/au1000/pb1000/board_setup.c	2003-08-25 11:44:39.000000000 +0000
+++ arch/mips/au1000/pb1000/board_setup.c	2004-01-06 12:42:40.000000000 +0000
@@ -186,7 +186,9 @@
 	case 0x02: /* HB */
 		break;
 	default:  /* HC and newer */
-		au_writel(0x00000060, 0xb190003c);
+		/* Enable sys bus clock divider when IDLE state or no bus 
+		   activity. */
+		au_writel(au_readl(SYS_POWERCTRL) | (0x3 << 5), SYS_POWERCTRL);
 		break;
 	}
 }
