--- arch/mips/momentum/ocelot_c/prom.c	2003-08-25 11:44:40.000000000 +0000
+++ arch/mips/momentum/ocelot_c/prom.c	2004-01-06 12:42:08.000000000 +0000
@@ -2,6 +2,9 @@
  * Copyright 2002 Momentum Computer Inc.
  * Author: Matthew Dharm <mdharm@momenco.com>
