 	bne-	50f
 	cmpli	0,r0,NR_syscalls
 	bge-	66f
@@ -91,10 +93,10 @@
  *
  */
 #ifdef CONFIG_BINFMT_ELF32
-	ld	r10,THREAD+THREAD_FLAGS(r13)
