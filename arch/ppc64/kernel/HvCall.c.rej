--- arch/ppc64/kernel/HvCall.c	2002-08-03 00:39:43.000000000 +0000
+++ arch/ppc64/kernel/HvCall.c	2004-01-06 12:45:12.000000000 +0000
@@ -1,7 +1,7 @@
 /*
