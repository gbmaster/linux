--- arch/ppc64/kernel/signal.c	2003-08-25 11:44:40.000000000 +0000
+++ arch/ppc64/kernel/signal.c	2004-01-06 12:46:10.000000000 +0000
@@ -296,7 +296,9 @@
 			newsp = (current->sas_ss_sp + current->sas_ss_size);
 	}
 
-        return (void *)((newsp - frame_size) & -8ul);
+	/* The ABI requires quadword alignment for the stack. */
+	return (void *)((newsp - frame_size) & -16ul);
+
 }
 
 static int
