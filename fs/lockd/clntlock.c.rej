--- fs/lockd/clntlock.c	2001-10-01 20:45:47.000000000 +0000
+++ fs/lockd/clntlock.c	2004-01-06 12:46:17.000000000 +0000
@@ -188,7 +188,8 @@
 		nlmclnt_prepare_reclaim(host, newstate);
 		nlm_get_host(host);
 		MOD_INC_USE_COUNT;
-		kernel_thread(reclaimer, host, CLONE_SIGNAL);
+		if (kernel_thread(reclaimer, host, CLONE_SIGNAL) < 0)
+			MOD_DEC_USE_COUNT;
 	}
 }
 
