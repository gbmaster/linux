 	set_pcf(adap, 1, I2C_PCF_PIN);
@@ -152,7 +151,7 @@
 	   PCF8584 does that when ESO is zero */
 	/* PCF also resets PIN bit */
 	if ((temp = get_pcf(adap, 1)) != (0)) {
