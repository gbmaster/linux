--- drivers/acpi/events/evgpe.c	2003-11-28 18:26:19.000000000 +0000
+++ drivers/acpi/events/evgpe.c	2004-01-06 12:45:24.000000000 +0000
@@ -139,12 +139,10 @@
 {
 	u32                             int_status = ACPI_INTERRUPT_NOT_HANDLED;
 	u8                              enabled_status_byte;
-	u8                              bit_mask;
 	struct acpi_gpe_register_info   *gpe_register_info;
 	u32                             in_value;
 	acpi_status                     status;
