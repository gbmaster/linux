--- include/asm-mips/lasat/lasat.h	2003-08-25 11:44:43.000000000 +0000
+++ include/asm-mips/lasat/lasat.h	2004-01-06 12:44:48.000000000 +0000
@@ -234,7 +234,8 @@
 
 extern unsigned int lasat_ndelay_divider;
 
-extern inline void lasat_ndelay(unsigned int ns) {
+static inline void lasat_ndelay(unsigned int ns)
+{
 	__delay(ns / lasat_ndelay_divider);
 }
 
