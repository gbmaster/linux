+	MOMENCO_JAGUAR_ATX_SERIAL_PORT_DEFNS		\
 	SEAD_SERIAL_PORT_DEFNS				\
-	STD_SERIAL_PORT_DEFNS
+	STD_SERIAL_PORT_DEFNS				\
+	TITAN_SERIAL_PORT_DEFNS
 
