--- include/asm-cris/page.h	2002-08-03 00:39:45.000000000 +0000
+++ include/asm-cris/page.h	2004-01-06 12:43:33.000000000 +0000
@@ -80,6 +80,20 @@
          BUG(); \
 } while (0)
 
+/* Pure 2^n version of get_order */
+static __inline__ int get_order(unsigned long size)
+{
+	int order;
+
+	size = (size-1) >> (PAGE_SHIFT-1);
+	order = -1;
+	do {
+		size >>= 1;
+		order++;
+	} while (size);
+	return order;
+}
+
 #endif /* __ASSEMBLY__ */
 
